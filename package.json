{
	"name": "mcp-sqlite-tools",
	"version": "0.0.17",
	"description": "MCP server for local SQLite database operations",
	"keywords": [
		"ai",
		"database",
		"llm",
		"local-database",
		"mcp",
		"model-context-protocol",
		"sql",
		"sqlite",
		"sqlite3"
	],
	"license": "MIT",
	"author": "Scott Spence",
	"bin": {
		"mcp-sqlite-tools": "./dist/index.js"
	},
	"files": [
		"dist",
		"package.json",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "vp pack",
		"start": "node dist/index.js",
		"dev": "vp pack --watch",
		"inspect": "npx @modelcontextprotocol/inspector dist/index.js",
		"clean": "rm -rf dist",
		"check": "vp check",
		"test": "vp test",
		"format": "vp check --fix",
		"format:check": "vp check",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish",
		"publish-mcp": "pnpm run sync-server-json && mcp-publisher publish",
		"sync-server-json": "node -e \"const pkg = require('./package.json'); const server = require('./server.json'); server.version = pkg.version; server.packages[0].version = pkg.version; require('fs').writeFileSync('./server.json', JSON.stringify(server, null, 2));\""
	},
	"dependencies": {
		"@tmcp/adapter-valibot": "^0.1.5",
		"@tmcp/transport-stdio": "^0.4.2",
		"better-sqlite3": "^12.8.0",
		"csv-parser": "^3.2.0",
		"csv-writer": "^1.6.0",
		"tmcp": "^1.19.3",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.1",
		"vite-plus": "^0.1.20",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"mcpName": "io.github.spences10/mcp-sqlite-tools"
}
